{
    "version": "6.0.1",
    "description": "Video player tailored for English learners",
    "homepage": "https://github.com/solidSpoon/DashPlayer",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/solidSpoon/DashPlayer/releases/download/v6.0.1/DashPlayer-6.0.1.setup.exe",
            "hash": "daeeb81ba1ced3e80234b9d7efe6b44b339e1345dfe26bca07489eff29fd383d"
        }
    },
    "installer": {
        "script": [
            "Expand-7zipArchive -Path \"$dir\\$fname\" -Removal",
            "Expand-7zipArchive -Path \"$dir\\dashplayer-$version-full.nupkg\" -ExtractDir 'lib\\net45' -Removal | Out-Null",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:AppData\\DashPlayer\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:AppData\\DashPlayer\""
    ],
    "shortcuts": [
        [
            "dash-player.exe",
            "DashPlayer"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/solidSpoon/DashPlayer/releases/download/v$version/DashPlayer-$version.setup.exe"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
