{
    "version": "2.0.9.1-Mydeimos",
    "description": "A Flutter BiliBili desktop client forked from PiliPlus, with offline cache support",
    "homepage": "https://github.com/Starfallan/PiliNara",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Starfallan/PiliNara/releases/download/2.0.9.1-Mydeimos/PiliNara_windows_2.0.9%2B5404_x64_portable.zip",
            "hash": "7425bb92913aeabbef3af90fb2ca29d0340f52bd9f657f8c01df39b930d0ccfb"
        }
    },
    "extract_dir": "PiliNara-Win",
    "shortcuts": [
        [
            "pilinara.exe",
            "PiliNara"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\com.example\\PiliNara\" \"$persist_dir\\AppData\" -Migrate",
            "New-PersistDirectory \"$env:LOCALAPPDATA\\com.example\\PiliNara\" \"$persist_dir\\LocalAppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\com.example\\PiliNara\"",
        "Remove-Junction \"$env:LOCALAPPDATA\\com.example\\PiliNara\"",
        "Remove-EmptyDirectory \"$env:APPDATA\\com.example\"",
        "Remove-EmptyDirectory \"$env:LOCALAPPDATA\\com.example\""
    ],
    "checkver": {
        "url": "https://api.github.com/repos/Starfallan/PiliNara/releases/latest",
        "regex": "/download/(?<version>[^/]+)/PiliNara_windows_(?<flutter>[\\d.]+)%2B(?<build>\\d+)_x64_portable\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Starfallan/PiliNara/releases/download/$version/PiliNara_windows_$matchFlutter%2B$matchBuild_x64_portable.zip"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
