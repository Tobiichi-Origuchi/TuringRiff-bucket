{
    "version": "1.3.3",
    "description": "An open-source screen recorder and editor for walkthroughs, demos, product videos, and more.",
    "homepage": "https://recordly.dev/",
    "license": "AGPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/webadderallorg/Recordly/releases/download/v1.3.3/Recordly-windows-x64.exe#/dl.7z",
            "hash": "5dedfaf900ca3b37be9328e871ee0192c67761148b89570ab115c8dad1a71a1b"
        }
    },
    "installer": {
        "script": [
            "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "Remove-Item \"$dir\\`$*\", \"$dir\\resources\\app-update.yml\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\Recordly\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\Recordly\"",
        "Remove-Item \"$env:LocalAppData\\recordly-updater\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null"
    ],
    "shortcuts": [
        [
            "Recordly.exe",
            "Recordly"
        ]
    ],
    "checkver": {
        "github": "https://github.com/webadderallorg/Recordly"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/webadderallorg/Recordly/releases/download/v$version/Recordly-windows-x64.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
